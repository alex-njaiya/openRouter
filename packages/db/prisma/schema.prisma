// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 Int                  @id @default(autoincrement())
  email              String               @unique
  password           String
  Api_keys           ApiKeys[]
  credits            Int                  @default(0)
  conversations      Conversations[]
  onramptransactions OnrampTransactions[]
}

model ApiKeys {
  id              Int       @id @default(autoincrement())
  user_id         Int
  name            String
  api_key         String    @unique
  disabled        Boolean   @default(false)
  deleted         Boolean   @default(false)
  lastUsed        DateTime?
  creditsConsumed Int       @default(0)

  user          User?           @relation(fields: [user_id], references: [id])
  conversations Conversations[]
}

model Companies {
  id      Int     @id @default(autoincrement())
  name    String  @unique
  website String  @unique
  models  Model[]
}

model Model {
  id         Int    @id @default(autoincrement())
  name       String @unique
  company_id Int
  slug       String

  company                 Companies?               @relation(fields: [company_id], references: [id])
  model_provider_mappings Model_Provider_Mapping[]
}

model Providers {
  id                      Int                      @id @default(autoincrement())
  name                    String
  website                 String
  model_provider_mappings Model_Provider_Mapping[]
}

model Model_Provider_Mapping {
  id              Int @id @default(autoincrement())
  model_id        Int
  provider_id     Int
  inputTokenCost  Int
  outputTokenCost Int

  model         Model           @relation(fields: [model_id], references: [id])
  provider      Providers       @relation(fields: [provider_id], references: [id])
  conversations Conversations[]
}

model Conversations {
  id                        Int    @id @default(autoincrement())
  user_id                   Int
  api_key_id                Int
  model_provider_mapping_id Int
  input                     String
  output                    String
  inputTokenCount           Int
  outputTokenCount          Int

  user                 User?                   @relation(fields: [user_id], references: [id])
  apiKey               ApiKeys?                @relation(fields: [api_key_id], references: [id])
  modelProviderMapping Model_Provider_Mapping? @relation(fields: [model_provider_mapping_id], references: [id])
}

model OnrampTransactions {
  id      Int    @id @default(autoincrement())
  user_id Int
  amount  Float
  status  String @default("processing")

  user User? @relation(fields: [user_id], references: [id])
}
